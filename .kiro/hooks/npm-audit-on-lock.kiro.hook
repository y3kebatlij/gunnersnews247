{
  "enabled": true,
  "name": "Dependency Vulnerability Audit",
  "description": "Runs npm audit when package-lock.json changes to check for known vulnerabilities in dependencies per the supply chain management rules.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/package-lock.json"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx npm-audit-fix-action 2>/dev/null || npm audit --audit-level=high 2>&1 | head -30",
    "timeout": 30
  }
}