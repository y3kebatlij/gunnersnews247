DYNAMODB_SOURCE_REGISTRY_TABLE=SourceRegistry
DYNAMODB_MATCHES_TABLE=Matches
DYNAMODB_MATCH_EVENTS_TABLE=MatchEvents
DYNAMODB_LINEUPS_TABLE=Lineups
DYNAMODB_STANDINGS_TABLE=Standings
